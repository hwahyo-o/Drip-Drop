rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function bootstrapAdminEmails() {
      return [""];
    }
    function isBootstrapAdminEmail() {
      return signedIn() && request.auth.token.email in bootstrapAdminEmails();
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function canCreateOwnUser(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && (
          request.resource.data.role == "user"
          || (request.resource.data.role == "admin" && isBootstrapAdminEmail())
        );
    }
    function canUpdateOwnUser(uid) {
      return isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && (
          request.resource.data.role == resource.data.role
          || (resource.data.role == "user" && request.resource.data.role == "admin" && isBootstrapAdminEmail())
        );
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if canCreateOwnUser(uid) || isAdmin();
      allow update: if canUpdateOwnUser(uid) || isAdmin();
      allow delete: if isAdmin();
    }
    match /cafes/{cafeId} {
      allow read: if (resource.data.approved == true && resource.data.naverVerified == true) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /favorites/{favoriteId} {
      allow read, delete: if signedIn() && request.auth.uid == resource.data.uid;
      allow create, update: if signedIn() && request.auth.uid == request.resource.data.uid;
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if signedIn() && request.auth.uid == resource.data.uid;
    }
    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if signedIn() && request.auth.uid == resource.data.uid;
    }
    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if signedIn() && request.auth.uid == resource.data.uid;
    }
    match /reactions/{reactionId} {
      allow read: if true;
      allow delete: if signedIn() && request.auth.uid == resource.data.uid;
      allow create, update: if signedIn() && request.auth.uid == request.resource.data.uid;
    }
    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.receiverUid;
      allow create: if signedIn();
    }
    match /annualReports/{reportId} {
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.uid;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
    }
  }
}
