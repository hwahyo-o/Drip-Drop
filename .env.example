# Copy to .env for local notes only. Do not commit .env.
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Static deploy note: Drip Drop reads the Naver Maps client id from js/mapConfig.js.
NAVER_MAP_CLIENT_ID=your_naver_maps_javascript_ncp_key_id

# Do not expose server-only secrets in client-side JavaScript.
IPSTACK_ACCESS_KEY=your_ipstack_access_key
